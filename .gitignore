# -------------------------------------------------------
# EasyDentalLab — repo .gitignore
# OS/editor junk is handled by ~/.gitignore_global
# -------------------------------------------------------

# User data files (contain live client/invoice data — never version these)
Clients.csv
Macros.csv
MedicalAids.csv
Payments.csv
EasyDentalLab-backup.json
EasyDentalLab-backup.encrypted

# Direct Claiming PDF output
Send to Direct Claiming/

# Claude Code internals
.claude/

# AI team operational files
Team/
Team Inbox/
Owner's Inbox/
larry_watch.sh

# -------------------------------------------------------
# Python (claude_server.py and future scripts)
# -------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.env
.venv
venv/
env/
*.egg-info/
dist/
build/

# -------------------------------------------------------
# Node / Electron / Tauri (desktop compilation)
# -------------------------------------------------------
node_modules/

# Electron build output (installers ~ 100 MB each)
EasyDentalLab-Desktop/build/
out/
dist/
release/
app/dist/

# Tauri build output
src-tauri/target/

# Package lock files (optional — remove these lines to track them)
# package-lock.json
# yarn.lock

# -------------------------------------------------------
# Certificates & secrets (never commit these)
# -------------------------------------------------------
*.pem
*.p12
*.key
*.crt
.env
.env.*
!.env.example
